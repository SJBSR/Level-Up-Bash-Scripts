#!/bin/bash

# Check if script is being run as root
if [[ $EUID -ne 0 ]]; then
    echo "Error: This script must be run as root!" >&2
    exit 1
fi

# Get user input
read -p "Enter username: "         username
read -p "Enter full name: "        fullname
read -p "Enter department: "	   group
read -p "Enter email address: "    email
read -s -p "Enter initial password: " password
echo

# Validate inputs are not empty
if [[ -z "$username" || -z "$fullname" || -z "$group" || -z "$email" || -z "$password" ]]; then
    echo "Error: All fields are required!" >&2
    exit 1
fi

# Check if user already exists
if id "$username" &>/dev/null; then
    echo "Error: User '$username' already exists!" >&2
    exit 1
fi

# Check if group exists
if ! getent group "$group" &>/dev/null; then
    echo "Error: Group '$group' does not exist!" >&2
    exit 1
fi

# Create the user
useradd -m -c "$fullname - $email" -g "$group" -s /bin/bash "$username"

if [[ $? -ne 0 ]]; then
    echo "Error: User creation failed!" >&2
    exit 1
fi

# Set the initial password
echo "$username:$password" | chpasswd

if [[ $? -ne 0 ]]; then
    echo "Error: Password could not be set!" >&2
    exit 1
fi

# Force password change on first login
passwd -e "$username"

# Display account details
echo
echo "User account successfully created!"
echo "----------------------------------"
echo "Username:   $username"
echo "Full Name:  $fullname"
echo "Department: $group"
echo "Email:	  $email"
echo "Password:   Set (user will be prompted to change on first login)"
echo "----------------------------------"
